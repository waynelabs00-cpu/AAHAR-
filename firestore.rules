rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSchoolStaff(schoolId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.firstName is string && data.firstName.size() <= 100
          && data.lastName is string && data.lastName.size() <= 100
          && data.email is string && data.email.size() <= 200
          && data.role in ['admin', 'principal', 'staff']
          && (data.schoolId == null || (data.schoolId is string && data.schoolId.size() <= 128));
      }

      // Allow a user to read their own profile, or admins can read all
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn(); // We might need to list users in the app
      
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId 
        && isValidUser(incoming()) 
        && data.keys().size() <= 6;
        
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin())
        && isValidUser(incoming())
        && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName']));
    }

    match /schools/{schoolId} {
      function isValidSchool(data) {
        return data.name is string && data.name.size() <= 200
          && data.schoolCode is string && data.schoolCode.size() <= 50
          && data.address is string && data.address.size() <= 500
          && data.totalStudents is number;
      }

      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidSchool(incoming());
      allow update: if isAdmin() && isValidSchool(incoming());
    }

    match /stockInventory/{itemId} {
      function isValidStock(data) {
        return data.schoolId is string && data.schoolId.size() <= 128
          && data.itemName is string && data.itemName.size() <= 100
          && data.quantity is number && data.quantity >= 0
          && data.unit is string && data.unit.size() <= 20;
      }

      allow read, list: if isSignedIn() && (isAdmin() || isSchoolStaff(resource.data.schoolId));
      allow create: if isSignedIn() && isValidStock(incoming()) && (isAdmin() || isSchoolStaff(incoming().schoolId));
      allow update: if isSignedIn() && isValidStock(incoming()) && (isAdmin() || isSchoolStaff(existing().schoolId));
    }

    match /dailyMeals/{mealId} {
      function isValidMeal(data) {
        return data.schoolId is string && data.schoolId.size() <= 128
          && data.date is string && data.date.size() <= 20
          && data.studentsServed is number && data.studentsServed >= 0
          && data.mealType in ['breakfast', 'lunch'];
      }

      allow read, list: if isSignedIn() && (isAdmin() || isSchoolStaff(resource.data.schoolId));
      allow create: if isSignedIn() && isValidMeal(incoming()) && (isAdmin() || isSchoolStaff(incoming().schoolId));
      allow update: if isSignedIn() && isValidMeal(incoming()) && (isAdmin() || isSchoolStaff(existing().schoolId));
    }
    match /students/{studentId} {
      function isValidStudent(data) {
        return data.schoolId is string && data.schoolId.size() <= 128
          && data.name is string && data.name.size() <= 100
          && data.class is string && data.class.size() <= 20
          && data.roll is string && data.roll.size() <= 20;
      }

      allow read, list: if isSignedIn() && (isAdmin() || isSchoolStaff(resource.data.schoolId));
      allow create: if isSignedIn() && isValidStudent(incoming()) && (isAdmin() || isSchoolStaff(incoming().schoolId));
      allow update: if isSignedIn() && isValidStudent(incoming()) && (isAdmin() || isSchoolStaff(existing().schoolId));
    }
  }
}
